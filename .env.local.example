# Resend — contact form email delivery
# Get your API key at https://resend.com
RESEND_API_KEY=

# Google Analytics 4 — set in Vercel for production
# Create a GA4 property at https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# reCAPTCHA v3 — spam protection for contact forms
# Get keys at https://www.google.com/recaptcha/admin
# Omit for development — test keys are used automatically
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
